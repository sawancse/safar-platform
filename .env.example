# Safar Platform — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=safar
DB_PASS=safar_dev
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/safar

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT (generate a secure base64-encoded 256-bit secret) ────────────────────
JWT_SECRET=l0UNaBuoYCf7Y/G8G1bihPxkUI7NZuPaZdzTbbEYqzM=

# ── AES-256 Encryption (for PII: Aadhaar, PAN, bank account) ────────────────
# Generate with: openssl rand -base64 32
# WARNING: rotating this value breaks every encrypted row in users schema.
# Pick a value once, store it safely (AWS Secrets Manager in prod).
ENCRYPTION_AES_KEY=replace-with-openssl-rand-base64-32
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# ── Kafka ─────────────────────────────────────────────────────────────────────
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BOOTSTRAP=localhost:9092

# ── Razorpay (Payment Service) ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── AWS / Media Service ───────────────────────────────────────────────────────
# Local dev only. In ECS/Fargate prod, leave these UNSET and use an IAM task role.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-iam-access-key
AWS_SECRET_ACCESS_KEY=your-iam-secret-key
AWS_S3_BUCKET=safar-media-dev
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# ── Email / Notification Service ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=sawank.sit@gmail.com
MAIL_PASSWORD=Telnet@987

# ── Twilio (SMS OTP / Auth Service) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Elasticsearch ─────────────────────────────────────────────────────────────
SPRING_ELASTICSEARCH_URIS=http://localhost:9200

# ── Service URLs (defaults to localhost for local dev) ────────────────────────
AUTH_SERVICE_URL=http://localhost:8888
USER_SERVICE_URL=http://localhost:8092
LISTING_SERVICE_URL=http://localhost:8083
SEARCH_SERVICE_URL=http://localhost:8084
BOOKING_SERVICE_URL=http://localhost:8095
PAYMENT_SERVICE_URL=http://localhost:8086
MEDIA_SERVICE_URL=http://localhost:8088
REVIEW_SERVICE_URL=http://localhost:8087
NOTIFICATION_SERVICE_URL=http://localhost:8089
AI_SERVICE_URL=http://localhost:8090
MESSAGING_SERVICE_URL=http://localhost:8091
CHEF_SERVICE_URL=http://localhost:8093
NOTIFICATION_BASE_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:*,https://ysafar.com,https://*.ysafar.com

# ── August Smart Lock ─────────────────────────────────────────────────────────
AUGUST_API_KEY=your_august_api_key
