{
  "info": {
    "name": "Safar Platform — Sprint 2",
    "description": "Search, Booking, Media, and Payment APIs for Sprint 2 (S5-S9)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "safar-sprint-2"
  },
  "variable": [
    { "key": "basePaymentUrl",  "value": "http://localhost:8086/api/v1" },
    { "key": "baseMediaUrl",    "value": "http://localhost:8088/api/v1" },
    { "key": "baseSearchUrl",   "value": "http://localhost:8084/api/v1" },
    { "key": "baseBookingUrl",  "value": "http://localhost:8085/api/v1" },
    { "key": "accessToken",     "value": "" },
    { "key": "bookingId",       "value": "" },
    { "key": "razorpayOrderId", "value": "" },
    { "key": "listingId",       "value": "" }
  ],
  "item": [
    {
      "name": "Payment Service — Subscription (S5)",
      "item": [
        {
          "name": "Create Subscription (STARTER)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{basePaymentUrl}}/payments/subscription/create?tier=STARTER",
              "query": [{ "key": "tier", "value": "STARTER" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('Invoice number format', () => pm.expect(body.invoiceNumber).to.match(/^SAF-INV-/));",
              "pm.test('Status ISSUED', () => pm.expect(body.status).to.eql('ISSUED'));"] }
          }]
        },
        {
          "name": "Get Invoices",
          "request": {
            "method": "GET",
            "url": "{{basePaymentUrl}}/payments/invoices",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Razorpay Webhook (subscription.charged)",
          "request": {
            "method": "POST",
            "url": "{{basePaymentUrl}}/payments/webhook/razorpay",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Razorpay-Signature", "value": "test_signature" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"event\":\"subscription.charged\",\"payload\":{\"subscription\":{\"entity\":{\"id\":\"sub_test123\"}}}}"
            }
          }
        }
      ]
    },
    {
      "name": "Media Service — Upload (S6)",
      "item": [
        {
          "name": "Get Presigned Upload URL (VIDEO)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseMediaUrl}}/media/upload/presign?mediaType=VIDEO&contentType=video/mp4&listingId={{listingId}}",
              "query": [
                { "key": "mediaType", "value": "VIDEO" },
                { "key": "contentType", "value": "video/mp4" },
                { "key": "listingId", "value": "{{listingId}}" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Has uploadUrl', () => pm.expect(body.uploadUrl).to.not.be.empty);",
              "pm.test('Has cdnUrl', () => pm.expect(body.cdnUrl).to.not.be.empty);"
            ] }
          }]
        },
        {
          "name": "Get Presigned Upload URL (PHOTO)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseMediaUrl}}/media/upload/presign?mediaType=PHOTO&contentType=image/jpeg&listingId={{listingId}}",
              "query": [
                { "key": "mediaType", "value": "PHOTO" },
                { "key": "contentType", "value": "image/jpeg" },
                { "key": "listingId", "value": "{{listingId}}" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Confirm Upload (VIDEO ≥60s)",
          "request": {
            "method": "POST",
            "url": "{{baseMediaUrl}}/media/upload/confirm",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mediaId\": \"00000000-0000-0000-0000-000000000001\",\n  \"listingId\": \"{{listingId}}\",\n  \"s3Key\": \"listings/{{listingId}}/video/test\",\n  \"mediaType\": \"VIDEO\",\n  \"durationSeconds\": 90\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Confirm Upload — Short Video (expect 400)",
          "request": {
            "method": "POST",
            "url": "{{baseMediaUrl}}/media/upload/confirm",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mediaId\": \"00000000-0000-0000-0000-000000000002\",\n  \"listingId\": \"{{listingId}}\",\n  \"s3Key\": \"listings/{{listingId}}/video/short\",\n  \"mediaType\": \"VIDEO\",\n  \"durationSeconds\": 30\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"] }
          }]
        }
      ]
    },
    {
      "name": "Search Service (S7)",
      "item": [
        {
          "name": "Search Listings by City",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseSearchUrl}}/search/listings?city=Mumbai",
              "query": [{ "key": "city", "value": "Mumbai" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Search Listings with Price Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseSearchUrl}}/search/listings?city=Mumbai&priceMin=200000&priceMax=800000",
              "query": [
                { "key": "city", "value": "Mumbai" },
                { "key": "priceMin", "value": "200000" },
                { "key": "priceMax", "value": "800000" }
              ]
            }
          }
        },
        {
          "name": "Search Listings — Geo (Bandra, Mumbai)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseSearchUrl}}/search/listings?lat=19.0596&lng=72.8295&radiusKm=5",
              "query": [
                { "key": "lat", "value": "19.0596" },
                { "key": "lng", "value": "72.8295" },
                { "key": "radiusKm", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "Autocomplete",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseSearchUrl}}/search/autocomplete?q=Mum",
              "query": [{ "key": "q", "value": "Mum" }]
            }
          }
        },
        {
          "name": "Trending in Mumbai",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseSearchUrl}}/search/trending?city=Mumbai",
              "query": [{ "key": "city", "value": "Mumbai" }]
            }
          }
        },
        {
          "name": "Nearby",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseSearchUrl}}/search/nearby?lat=19.0596&lng=72.8295&radiusKm=5&limit=10",
              "query": [
                { "key": "lat", "value": "19.0596" },
                { "key": "lng", "value": "72.8295" },
                { "key": "radiusKm", "value": "5" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Booking Service (S8)",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "url": "{{baseBookingUrl}}/bookings",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"checkIn\": \"2025-12-20T14:00:00\",\n  \"checkOut\": \"2025-12-25T11:00:00\",\n  \"guestsCount\": 2\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('bookingId', body.id);",
              "pm.test('Status PENDING_PAYMENT', () => pm.expect(body.status).to.eql('PENDING_PAYMENT'));",
              "pm.test('Booking ref format', () => pm.expect(body.bookingRef).to.match(/^SAF-BKG-/));"
            ] }
          }]
        },
        {
          "name": "Get Booking",
          "request": {
            "method": "GET",
            "url": "{{baseBookingUrl}}/bookings/{{bookingId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseBookingUrl}}/bookings/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Host Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseBookingUrl}}/bookings/host",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Confirm Booking",
          "request": {
            "method": "POST",
            "url": "{{baseBookingUrl}}/bookings/{{bookingId}}/confirm",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status CONFIRMED', () => pm.expect(pm.response.json().status).to.eql('CONFIRMED'));"
            ] }
          }]
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseBookingUrl}}/bookings/{{bookingId}}/cancel?reason=Change of plans",
              "query": [{ "key": "reason", "value": "Change of plans" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Payment Service — Booking Payment (S9)",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{basePaymentUrl}}/payments/order?bookingId={{bookingId}}&amountPaise=3025000",
              "query": [
                { "key": "bookingId", "value": "{{bookingId}}" },
                { "key": "amountPaise", "value": "3025000" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('razorpayOrderId', body.razorpayOrderId);",
              "pm.test('Has razorpayOrderId', () => pm.expect(body.razorpayOrderId).to.not.be.empty);",
              "pm.test('Has razorpayKeyId', () => pm.expect(body.razorpayKeyId).to.not.be.empty);"
            ] }
          }]
        },
        {
          "name": "Razorpay Webhook (payment.captured)",
          "request": {
            "method": "POST",
            "url": "{{basePaymentUrl}}/payments/webhook/razorpay",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Razorpay-Signature", "value": "test_signature" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"event\":\"payment.captured\",\"order_id\":\"{{razorpayOrderId}}\"}"
            }
          }
        },
        {
          "name": "Initiate Host Payout",
          "request": {
            "method": "POST",
            "url": "{{basePaymentUrl}}/payments/payout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"amountPaise\": 2500000,\n  \"upiId\": \"host@upi\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"] }
          }]
        }
      ]
    }
  ]
}
